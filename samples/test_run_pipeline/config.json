{
  "profiler_config" : {
    "enable_profiling" : false
  },

  "source" : {
    "class_name" : "unistream::DataSource",
	"parallelism" : 0,
	"next_modules" : ["inference"],
    "custom_params" : {
		"bufpool_size" : 16,
		"interval" : 1,
		"device_id" : 0
	 }
  },

  "inference" : {
    "class_name" : "unistream::Inferencer",
	"parallelism" : 1,
	"max_input_queue_size" : 20,
	"next_modules" : ["osd"],
	"custom_params" : {
	    "model_path" : "../../data/models/yolo11x.axmodel",
	    "preproc"  : "name=PreprocYolov11;use_cpu=false",
		"postproc" : "name=PostprocYolov11;threshold=0.5",
		"batch_timeout" : 300,
		"engine_num" : 1,
		"model_input_pixel_format" : "BGR24",
		"device_id" : 0
	 }
  },

  "osd" : {
	"class_name" : "unistream::Osd",
	"parallelism" : 1,
	"max_input_queue_size" : 20,
	"next_modules" : ["encoder"],
    "custom_params" : {
		"label_path" : "../../data/models/label_map_yolo11.txt"
	 }
  },
  
  "encoder" : {
    "class_name" : "unistream::VEncode", 
	"parallelism" : 1,
	"max_input_queue_size" : 20,
    "custom_params" : {
		"dst_width": "1920",
		"dst_height": "1080",
		"frame_rate": "25",
		"file_name": "./output/output.h264",
		"device_id": 0
	}
  }
}
